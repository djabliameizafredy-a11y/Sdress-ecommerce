rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'vendeuradmin1945@gmail.com' ||
        request.auth.uid == 'WvJbwhZ47IPIHtShtyJGfjQC1Vq1' ||
        request.auth.uid == 'bGdBJwkfcwgtP0PxCBwopInYhsz1'
      );
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100
        && data.newPrice is number && data.newPrice > 0
        && data.initialPrice is number && data.initialPrice >= 0
        && data.category in ['vetement', 'pantalon', 'chaussure', 'accessoire']
        && data.imageUrl is string && data.imageUrl.size() > 0;
    }

    // Products: Everyone can read, Admin can write with validation
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    // Config: Everyone can read whatsapp, Admin can write anything
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Force default deny for any accidental other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
