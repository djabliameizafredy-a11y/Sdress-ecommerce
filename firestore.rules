rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'VendeurAdmin1945@gmail.com';
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Products collection
    match /products/{productId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    // Config collection
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
