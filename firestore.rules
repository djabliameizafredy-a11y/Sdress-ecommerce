rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower() == 'vendeuradmin1945@gmail.com';
    }

    // --- Match Blocks ---

    // Products: Everyone can read, only Admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Config: Everyone can read, only Admin can write
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for everything else to maintain security
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
