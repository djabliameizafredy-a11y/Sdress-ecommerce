rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'vendeuradmin1945@gmail.com' &&
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'newPrice', 'imageUrl', 'createdAt']) &&
             data.keys().size() <= 10 && // Allow for some optional fields like initialPrice, isPromotion
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.category in ['vetement', 'pantalon', 'chaussure', 'accessoire'] &&
             data.newPrice is number && data.newPrice >= 0 &&
             data.imageUrl is string && data.imageUrl.size() <= 500 &&
             data.createdAt is number;
    }

    function isValidConfig(data) {
      return data.whatsappLink is string && data.whatsappLink.size() <= 200;
    }

    // --- Match Blocks ---

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /config/{configId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(configId) && isValidConfig(incoming());
      allow delete: if isAdmin();
    }
  }
}
